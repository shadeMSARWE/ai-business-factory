# AI Business Factory API Keys
# Copy to .env.local and add your keys. Never commit .env.local to git.

# OpenAI API key for AI text generation (website content, ads, SEO)
# Without it: mock/sample content is used
OPENAI_API_KEY=

# Unsplash Access Key for dynamic image fetching
# Without it: fallback placeholder images are used
UNSPLASH_ACCESS_KEY=

# Google Maps API key for Business Finder (Places API)
# Without it: mock business data is used
GOOGLE_MAPS_API_KEY=
