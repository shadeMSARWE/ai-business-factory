# AI Business Factory - Environment Configuration
# Copy to .env.local and add your keys. Never commit .env.local to git.

# AI & Images
OPENAI_API_KEY=
GOOGLE_MAPS_API_KEY=

# Supabase (Auth + Database)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# PayPal (Subscriptions)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# PayPal Subscription Plans (Starter→pro, Pro→business, Business→agency)
PAYPAL_PRO_PLAN_ID=
PAYPAL_BUSINESS_PLAN_ID=
PAYPAL_AGENCY_PLAN_ID=

# PayPal Webhook
PAYPAL_WEBHOOK_SECRET=
# Optional: Webhook ID from PayPal Dashboard (for signature verification)
PAYPAL_WEBHOOK_ID=

# Optional PayPal Mode (sandbox | live)
PAYPAL_ENV=live
